# WebdriverIO BDD Framework - Environment Configuration
# Copy this file to .env and update values for your environment

# ===========================
# Application Configuration
# ===========================
BASE_URL=https://practice.saucedemo.com

# ===========================
# Execution Mode (CHOOSE ONE)
# ===========================
# SET TO: 'true' to use Docker Selenium Chrome (requires docker-compose)
# SET TO: 'false' or leave blank to use local ChromeDriver (default)
USE_DOCKER=false

# ===========================
# Selenium/Browser Configuration
# ===========================
# Only used if USE_DOCKER=true
SELENIUM_PROTOCOL=http
SELENIUM_HOST=localhost
SELENIUM_PORT=4444

# Browser options
HEADLESS=true
SCREENSHOT_ON_FAILURE=true
VIDEO_ON_FAILURE=false

# Chrome options
CHROME_ARGS=--disable-dev-shm-usage,--no-sandbox,--disable-gpu

# ===========================
# Test Configuration
# ===========================
LOG_LEVEL=warn
TIMEOUT=10000
WAIT_FOR_TIMEOUT=10000
CONNECTION_RETRY_TIMEOUT=120000
CONNECTION_RETRY_COUNT=3

# Test execution
RETRY_COUNT=0
FAIL_FAST=false
MAX_INSTANCES=1

# Tags to run (leave empty to run all)
# Examples: @smoke, @regression, @critical
TAGS=

# ===========================
# CI/CD Configuration
# ===========================
CI=false
RUN_PARALLEL=false

# ===========================
# Reporting Configuration
# ===========================
ALLURE_REPORT=true
REPORT_DIR=allure-results

# ===========================
# Debug/Development
# ===========================
DEBUG=false
VERBOSE=false
