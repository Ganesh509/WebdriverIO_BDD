{
  "name": "webdriverio-bdd",
  "version": "1.0.0",
  "description": "WebdriverIO BDD testing framework with Cucumber",
  "author": "Your Team",
  "license": "MIT",
  "type": "commonjs",

  "scripts": {
    "test": "wdio run ./wdio.conf.js",
    "test:smoke": "wdio run ./wdio.conf.js --grep @smoke",
    "test:regression": "wdio run ./wdio.conf.js --grep @regression",
    "test:docker": "docker-compose -f docker-compose.yml up --abort-on-container-exit",
    "test:parallel": "wdio run ./wdio.conf.js --maxInstances 5",
    "test:debug": "wdio debug ./wdio.conf.js",
    "report:allure": "allure generate allure-results -o allure-report && allure open allure-report",
    "lint": "eslint features/ --fix",
    "format": "prettier --write 'features/**/*.js'",
    "clean": "rm -rf allure-results allure-report node_modules package-lock.json"
  },

  "devDependencies": {
    "@cucumber/cucumber": "^10.0.0",
    "@eslint/js": "^9.0.0",
    "@wdio/allure-reporter": "^9.26.1",
    "@wdio/cli": "^9.26.0",
    "@wdio/cucumber-framework": "^9.25.0",
    "@wdio/local-runner": "^9.25.0",
    "@wdio/spec-reporter": "^9.25.0",
    "allure-commandline": "^2.38.0",
    "chai": "^4.3.10",
    "chromedriver": "^149.0.0",
    "dotenv": "^16.3.1",
    "eslint": "^9.0.0",
    "prettier": "^3.1.0"
  }
}

